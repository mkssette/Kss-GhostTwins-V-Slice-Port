import funkin.play.cutscene.dialogue.Conversation;
import funkin.audio.FunkinSound;
import funkin.Paths;
import funkin.graphics.FunkinSprite;
import flixel.FlxG;
import funkin.Assets;
import StringTools;

class ScuffleConversation extends Conversation {

  var currentVoiceLine:FunkinSound;
  var silenceSound:FunkinSound;
  
  var layerBack:FunkinSprite;
  var layerMiddle:FunkinSprite;
  var layerFront:FunkinSprite;

  var imageScale:Float = 0.35;
  var offsetX:Float = 0;
  var offsetY:Float = 0;

  var watcherActive:Bool = false; 
  var lastRegisteredAnim:String = "";

  function new() {
    super('scuffle');
  }

  override function onCreate(event) {
    super.onCreate(event);

    lastRegisteredAnim = ""; 
    watcherActive = true;
    
    silenceSound = FunkinSound.load(Paths.sound('null_sound'), 0);

    layerBack = new FunkinSprite(0, 0);
    layerBack.zIndex = 10; 
    layerBack.antialiasing = true;
    layerBack.visible = false;
    this.add(layerBack);

    layerMiddle = new FunkinSprite(0, 0);
    layerMiddle.zIndex = 11; 
    layerMiddle.antialiasing = true;
    layerMiddle.visible = false;
    this.add(layerMiddle);

    layerFront = new FunkinSprite(0, 0);
    layerFront.zIndex = 12; 
    layerFront.antialiasing = true;
    layerFront.visible = false;
    this.add(layerFront);
    
    this.refresh();

    watcherActive = true;
  }

  override function onDialogueLine(event) {
    super.onDialogueLine(event);
    watcherActive = true;
  }

  override function onUpdate(event) {
    super.onUpdate(event);

    if (this.currentDialogueBox != null && this.currentDialogueBox.textDisplay != null) {
        if (!this.currentDialogueBox.textDisplay.sounds.contains(silenceSound)) {
            this.currentDialogueBox.textDisplay.sounds = [silenceSound];
        }
    }

    if (!watcherActive) return;
    if (this.currentSpeaker == null) return;

    var currentAnim:String = "";
    if (this.currentSpeaker.animation.curAnim != null) {
        currentAnim = this.currentSpeaker.animation.curAnim.name;
    }

    if (currentAnim != "" && currentAnim != lastRegisteredAnim) {
        trace("Nuevo dialogo detectado -> " + currentAnim);
        lastRegisteredAnim = currentAnim;

        if (this.currentSpeaker.id == "scuffle-speaker") {
            configureScene(currentAnim);
        }
        watcherActive = false;
    }
  }

  function configureScene(anim:String):Void {
    var imgBack:String = "";
    var imgMiddle:String = "";
    var imgFront:String = "";
    var audioFile:String = "";

    switch(anim) {
        case "CUT1":
            imgBack = "SCENE1";
            imgMiddle = "";
            imgFront = "";
            audioFile = "CUT1";

        case "CUT2":
            imgBack = "SCENE1";
            imgMiddle = "";
            imgFront = "";
            audioFile = "CUT2"; 

        case "CUT3":
            imgBack = "SCENE2";
            imgMiddle = "";
            imgFront = "";
            audioFile = "CUT3";

        case "CUT4":
            imgBack = "SCENE3";
            imgMiddle = "";
            imgFront = "";
            audioFile = "CUT4";

        case "CUT5":
            imgBack = "SCENE3";
            imgMiddle = "";
            imgFront = "";
            audioFile = "CUT5";

        case "CUT6":
            imgBack = "SCENE4";
            imgMiddle = "";
            imgFront = "";
            audioFile = "CUT6";

        case "CUT7":
            imgBack = "SCENE4";
            imgMiddle = "";
            imgFront = "";
            audioFile = "CUT7";

        case "CUT8":
            imgBack = "SCENE5";
            imgMiddle = "";
            imgFront = "";
            audioFile = "CUT8";

        case "CUT9":
            imgBack = "SCENE5";
            imgMiddle = "";
            imgFront = "";
            audioFile = "CUT9";

        case "CUT10":
            imgBack = "SCENE6";
            imgMiddle = "";
            imgFront = "";
            audioFile = "CUT10";

        case "CUT11":
            imgBack = "SCENE7";
            imgMiddle = "";
            imgFront = "";
            audioFile = "CUT11";

        case "CUT12":
            imgBack = "SCENE8";
            imgMiddle = "";
            imgFront = "";
            audioFile = "CUT12";

        case "CUT13":
            imgBack = "SCENE9";
            imgMiddle = "";
            imgFront = "";
            audioFile = "CUT13";

        case "CUT14":
            imgBack = "SCENE10";
            imgMiddle = "";
            imgFront = "";
            audioFile = "CUT14";
            
        case "CUT15":
            imgBack = "SCENE11";
            imgMiddle = "";
            imgFront = "";
            audioFile = "CUT15";

        case "CUT16":
            imgBack = "SCENE11";
            imgMiddle = "";
            imgFront = "";
            audioFile = "CUT16";

        case "CUT17":
            imgBack = "SCENE12";
            imgMiddle = "";
            imgFront = "";
            audioFile = "CUT17";

        case "CUT18":
            imgBack = "SCENE13";
            imgMiddle = "";
            imgFront = "";
            audioFile = "CUT18";

default:
            if (anim.indexOf("CUT") != -1) {
                
                audioFile = anim;

                var sceneName = StringTools.replace(anim, "CUT", "SCENE");
                
                imgBack = sceneName;
                imgMiddle = "";
                imgFront = sceneName + "-1";
            }
    }

    processImage(layerBack, imgBack);
    processImage(layerMiddle, imgMiddle);
    processImage(layerFront, imgFront);
    playVoiceLine(audioFile);
    
    this.refresh();
  }

  function processImage(sprite:FunkinSprite, fileName:String):Void {
    if (fileName == "") {
        sprite.visible = false;
        return;
    }

    var fullPath:String = 'dialogue/scuffle/' + fileName;

    if (Assets.exists(Paths.image(fullPath), "IMAGE")) {
        sprite.visible = true;
        sprite.loadGraphic(Paths.image(fullPath));
        sprite.scale.set(imageScale, imageScale);
        sprite.updateHitbox(); 
        sprite.screenCenter();
        sprite.x += offsetX;
        sprite.y += offsetY;
    } else {
        sprite.visible = false; 
    }
  }

  function playVoiceLine(audioName:String):Void {
    if (audioName == "") {
        if (currentVoiceLine != null) currentVoiceLine.stop();
        return;
    }

    if (currentVoiceLine != null && currentVoiceLine.isPlaying) {
      currentVoiceLine.stop();
    }
    
    var soundPath:String = 'dialogue/scuffle/' + audioName;
    
    if (Assets.exists(Paths.sound(soundPath), "SOUND")) {
       currentVoiceLine = FunkinSound.playOnce(Paths.sound(soundPath), 1.0);
    }
  }
  
  override function onDestroy(event) {
    super.onDestroy(event);
    if (currentVoiceLine != null) currentVoiceLine.stop();
  }
}