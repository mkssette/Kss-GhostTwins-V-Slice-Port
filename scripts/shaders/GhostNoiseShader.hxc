import flixel.addons.display.FlxRuntimeShader;
import openfl.utils.Assets;
import funkin.Paths;

class GhostNoiseShader extends FlxRuntimeShader
{
  public var iTime:Float = 0.0;

  public function new()
  {
    var fragText:String = Assets.getText(Paths.frag('ghostnoise'));
    super(fragText);
    
    setFloat('iTime', 0.0);
  }

  public function update(elapsed:Float):Void
  {
    iTime += elapsed;
    setFloat('iTime', iTime);
  }
}